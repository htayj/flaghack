{
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.10.0",
  "license": "AGPL-3.0-or-later",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "codegen": "pnpm --recursive --parallel run codegen",
    "build": "tsc -b tsconfig.build.json && pnpm --recursive --parallel run build",
    "check": "tsc -b tsconfig.json",
    "cli:tsx": "tsx packages/cli/src/bin.ts playB",
    "cli": "cd packages/cli/; pnpm run dev",
    "cli:old": "tsx packages/server/src/cli.tsx",
    "serve": "cd packages/server/; pnpm run dev",
    "testBSP": "tsx packages/server/src/testBSP.ts",
    "check-recursive": "pnpm --recursive exec tsc -b tsconfig.json",
    "lint": "eslint \"**/{src,test,examples,scripts,dtslint}/**/*.{ts,mjs}\"",
    "lint-fix": "pnpm lint --fix",
    "format": "dprint fmt",
    "format:check": "dprint check",
    "generated:guard": "node scripts/check-generated-guardrails.mjs",
    "test": "vitest run --workspace vitest.workspace.ts",
    "test:watch": "vitest --workspace vitest.workspace.ts",
    "test:unit": "vitest run --workspace vitest.workspace.ts",
    "test:perf": "vitest bench --config vitest.bench.ts --run",
    "test:api": "tsx scripts/api-smoke.ts",
    "test:e2e:tmux": "tsx scripts/tmux-e2e-smoke.ts",
    "coverage": "vitest run --coverage --workspace vitest.workspace.ts",
    "verify:smoke": "pnpm generated:guard && pnpm test:unit && pnpm test:perf && pnpm test:api && pnpm test:e2e:tmux",
    "verify:gates": "pnpm generated:guard && pnpm check && pnpm test:unit && pnpm test:perf && pnpm test:api && pnpm test:e2e:tmux"
  },
  "devDependencies": {
    "@babel/cli": "^7.27.2",
    "@babel/core": "^7.27.4",
    "@babel/plugin-transform-export-namespace-from": "^7.27.1",
    "@babel/plugin-transform-modules-commonjs": "^7.27.1",
    "@effect/build-utils": "^0.7.9",
    "@effect/eslint-plugin": "^0.2.0",
    "@effect/language-service": "^0.2.0",
    "@effect/platform": "^0.85.2",
    "@effect/platform-node": "^0.86.4",
    "@effect/vitest": "0.23.8",
    "@eslint/compat": "1.2.2",
    "@eslint/eslintrc": "3.1.0",
    "@eslint/js": "9.13.0",
    "@types/node": "^22.15.32",
    "@typescript-eslint/eslint-plugin": "^8.34.1",
    "@typescript-eslint/parser": "^8.34.1",
    "@vitest/coverage-v8": "^2.1.9",
    "babel-plugin-annotate-pure-calls": "^0.4.0",
    "dprint": "^0.49.1",
    "effect": "^3.16.8",
    "eslint": "^9.29.0",
    "eslint-import-resolver-typescript": "^3.10.1",
    "eslint-plugin-codegen": "^0.29.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-sort-destructure-keys": "^2.0.0",
    "glob": "^11.0.3",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "typescript-language-server": "^4.3.4",
    "vitest": "^2.1.9"
  },
  "pnpm": {
    "overrides": {
      "@effect/cli": "0.64.2",
      "@effect/platform": "0.85.2",
      "@effect/platform-browser": "0.65.2",
      "@effect/platform-node": "0.86.4",
      "@effect/vitest": "0.23.8",
      "vitest": "^2.0.5",
      "effect": "3.16.8"
    },
    "patchedDependencies": {
      "babel-plugin-annotate-pure-calls@0.4.0": "patches/babel-plugin-annotate-pure-calls@0.4.0.patch"
    }
  }
}
